---
import Base from '../layouts/Base.astro';
import { STATUS_LABELS, slugify } from '../lib/utils';
import playersData from '../../data/players.json';

// Ordina per valore di mercato (chi non ha valore va in coda, per classe)
const players = [...playersData.players].sort(
  (a, b) => (b.value ?? -1) - (a.value ?? -1) || b.born - a.born
);
const fmtValue = (v: number | undefined) =>
  v == null ? '—' : `€${v % 1 === 0 ? v : v.toFixed(1).replace('.', ',')}M`;
---

<Base
  title="Giocatori seguiti — Italian Next Gen"
  description="La watchlist dei giovani talenti italiani seguiti ogni giorno da Italian Next Gen."
  lang="it"
  altPath="/en/players/"
>
  <h1>La watchlist <span style="color:var(--gold)">({players.length})</span></h1>
  <p style="max-width:46rem; color:#aebdd8">
    I giovani azzurri che seguiamo ogni giorno, dalla Serie A ai Giovanissimi, dall'Italia
    a tutta Europa. Clicca su un nome per la scheda completa, o sulla ★ per aggiungerlo
    ai tuoi preferiti.
  </p>
  <table class="players-table">
    <thead>
      <tr><th></th><th>Giocatore</th><th>Club</th><th>Ruolo</th><th>Classe</th><th>Valore</th><th>Dove</th></tr>
    </thead>
    <tbody>
      {players.map((p) => (
        <tr>
          <td><button class="fav-btn small" data-slug={slugify(p.name)} aria-label={`Aggiungi ${p.name} ai preferiti`}>★</button></td>
          <td><a href={`/giocatori/${slugify(p.name)}/`} style="color:var(--ink); text-decoration:none; font-weight:600">{p.name}</a></td>
          <td>{p.club}</td>
          <td>{p.role}</td>
          <td>{p.born}</td>
          <td style="color:var(--gold); font-weight:600; white-space:nowrap">{fmtValue(p.value)}</td>
          <td><span class={`pill ${p.status}`}>{STATUS_LABELS[p.status].it}</span></td>
        </tr>
      ))}
    </tbody>
  </table>
  <p class="meta" style="margin-top:.8rem">
    Valori di mercato: {playersData.valueSource}. I giocatori senza valore non compaiono in quella classifica.
  </p>
</Base>
