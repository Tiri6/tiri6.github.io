---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Cover from '../../components/Cover.astro';
import { CATEGORY_LABELS, formatDate, slugify } from '../../lib/utils';
import { filterPublished, sortByPublished } from '../../lib/articles';
import playersData from '../../../data/players.json';
import perfData from '../../../data/performances.json';
import compData from '../../../data/competitions.json';

const compShort = Object.fromEntries(compData.competitions.map((c) => [c.id, c.shortEn]));

const posts = sortByPublished(filterPublished(await getCollection('news')));

const editoriale = posts.find((p) => p.data.category === 'editoriale');
const taccuino = posts.find((p) => p.data.category === 'taccuino');
const featuredIds = new Set([editoriale?.id, taccuino?.id].filter(Boolean));
const rest = posts.filter((p) => !featuredIds.has(p.id));

const performances = perfData.performances
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 8);

const nPlayers = playersData.players.length;
const nAbroad = playersData.players.filter((p) => p.status === 'estero').length;
const totGoals = perfData.performances.reduce((s, p) => s + (p.goals ?? 0), 0);
const totAssists = perfData.performances.reduce((s, p) => s + (p.assists ?? 0), 0);
---

<Base
  title="Italian Next Gen — Italy's young talents, every day"
  description="Daily news on every young Italian footballer: performances, transfers, youth national teams. The goal: World Cup 2030."
  lang="en"
  altPath="/"
>
  <div class="hero">
    <div class="kicker">Talent Intelligence · Italian Football</div>
    <h1>The road to <span class="gold">2030</span> starts today.</h1>
    <p>
      After three missed World Cups, Italy cannot afford to lose sight of a single talent.
      Our radar covers Serie A, B and C, Primavera, Next Gen sides, youth leagues
      and every pitch in Europe where an Italian kid is playing — every single day.
    </p>
    <div class="wc-countdown" data-target="2030-06-08T18:00:00Z">
      <div class="wc-label">− World Cup 2030 · Spain·Portugal·Morocco</div>
      <div class="wc-digits">
        <span><b class="d-days">—</b><i>days</i></span>
        <span><b class="d-hours">—</b><i>hrs</i></span>
        <span><b class="d-mins">—</b><i>min</i></span>
        <span><b class="d-secs">—</b><i>sec</i></span>
      </div>
    </div>
  </div>

  {(editoriale || taccuino) && (
    <>
      <div class="section-title">✦ Featured</div>
      <div class="featured-duo">
        {[editoriale, taccuino].filter(Boolean).map((post) => (
          <article class="card">
            <a href={`/en/news/${post.id}/`}>
              <Cover
                seed={post.id}
                players={post.data.players}
                category={post.data.category}
                image={post.data.image}
                alt={post.data.titleEn}
                compact
              />
            </a>
            <div>
              <span class="badge" style={`background:${CATEGORY_LABELS[post.data.category].color}`}>
                {post.data.category === 'editoriale' ? "The week's editorial" : 'The daily notebook'}
              </span>
              <span class="meta" style="margin-left:.6rem">{formatDate(post.data.date, 'en')}</span>
            </div>
            <h2><a href={`/en/news/${post.id}/`}>{post.data.titleEn}</a></h2>
            <p class="excerpt">{post.data.excerptEn}</p>
          </article>
        ))}
      </div>
    </>
  )}

  <div class="fav-strip" id="fav-strip">
    <div class="section-title">★ Your favourites</div>
    <div class="fav-chips" id="fav-chips"></div>
  </div>
  <script
    type="application/json"
    id="players-data"
    set:html={JSON.stringify(
      playersData.players.map((p) => ({ s: slugify(p.name), n: p.name, c: p.club }))
    )}
  />
  <script is:inline>
    (function () {
      const players = JSON.parse(document.getElementById('players-data').textContent);
      const strip = document.getElementById('fav-strip');
      const chips = document.getElementById('fav-chips');
      const render = () => {
        let favs = [];
        try { favs = JSON.parse(localStorage.getItem('ing-favs') || '[]'); } catch {}
        const mine = players.filter((p) => favs.includes(p.s));
        strip.classList.toggle('has-favs', mine.length > 0);
        chips.innerHTML = mine
          .map((p) => `<a class="fav-chip" href="/en/players/${p.s}/"><span class="star">★</span>${p.n}<span class="c">${p.c}</span></a>`)
          .join('');
      };
      document.addEventListener('ing-favs-changed', render);
      render();
    })();
  </script>

  <div class="section-title">◉ The Azzurri radar</div>
  <div class="stats-bar">
    <div class="stat-block"><div class="n">{nPlayers}</div><div class="l">Talents tracked</div></div>
    <div class="stat-block"><div class="n">{nAbroad}</div><div class="l">Abroad</div></div>
    <div class="stat-block"><div class="n">{totGoals}</div><div class="l">Goals in recent weeks</div></div>
    <div class="stat-block"><div class="n">{totAssists}</div><div class="l">Assists in recent weeks</div></div>
  </div>
  <div class="perf-strip">
    {performances.map((p) => (
      <div class="perf-card">
        <div class="perf-date">{formatDate(new Date(p.date), 'en')}</div>
        <div class="perf-top">
          <span class="perf-player">{p.player}</span>
          {p.rating != null && <span class="perf-rating">{p.rating.toFixed(1)}</span>}
        </div>
        <div class="perf-match">{p.club} — {p.opponent} · {p.result} · {p.competition}</div>
        <div class="perf-stats">
          {p.minutes != null && <span class="stat">{p.minutes}′</span>}
          {(p.goals ?? 0) > 0 && <span class="stat hot">⚽ {p.goals} {p.goals === 1 ? 'goal' : 'goals'}</span>}
          {(p.assists ?? 0) > 0 && <span class="stat hot">🅰 {p.assists} {p.assists === 1 ? 'assist' : 'assists'}</span>}
        </div>
        <p class="perf-note">{p.noteEn}</p>
        {p.sourceUrl && (
          <a class="perf-src" href={p.sourceUrl} target="_blank" rel="noopener">source: {p.source ?? 'link'}</a>
        )}
      </div>
    ))}
  </div>

  <div class="section-title">◉ Latest news</div>
  <div class="grid">
    {rest.map((post) => (
      <article class="card">
        <a href={`/en/news/${post.id}/`}>
          <Cover
            seed={post.id}
            players={post.data.players}
            category={post.data.category}
            image={post.data.image}
            alt={post.data.titleEn}
            compact
          />
        </a>
        <div>
          <span class="badge" style={`background:${CATEGORY_LABELS[post.data.category].color}`}>
            {CATEGORY_LABELS[post.data.category].en}
          </span>
          <span class="meta" style="margin-left:.6rem">{formatDate(post.data.date, 'en')}</span>
        </div>
        <h3><a href={`/en/news/${post.id}/`}>{post.data.titleEn}</a></h3>
        <p class="excerpt">{post.data.excerptEn}</p>
        {post.data.players.length > 0 && (
          <div class="players">⚽ {post.data.players.join(' · ')}</div>
        )}
        {post.data.competitions.length > 0 && (
          <div>{post.data.competitions.map((id) => compShort[id] && <a class="comp-tag" href={`/en/national-teams/${id}/`}>{compShort[id]}</a>)}</div>
        )}
      </article>
    ))}
  </div>
</Base>
